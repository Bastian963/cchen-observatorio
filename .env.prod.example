# Copia este archivo a .env.prod en la VM y ajusta rutas/hosts si TI define otros valores.

OBSERVATORIO_DASHBOARD_HOST=obs-int.cchen.cl
OBSERVATORIO_DSPACE_HOST=repo-int.cchen.cl
OBSERVATORIO_CKAN_HOST=datos-int.cchen.cl

OBSERVATORIO_DASHBOARD_URL=https://obs-int.cchen.cl
OBSERVATORIO_DSPACE_UI_URL=https://repo-int.cchen.cl
OBSERVATORIO_DSPACE_SERVER_URL=https://repo-int.cchen.cl/server
OBSERVATORIO_DSPACE_API_URL=https://repo-int.cchen.cl/server/api
OBSERVATORIO_CKAN_URL=https://datos-int.cchen.cl
OBSERVATORIO_CKAN_API_URL=https://datos-int.cchen.cl/api/3/action/status_show

OBSERVATORIO_HTTP_PORT=80
OBSERVATORIO_HTTPS_PORT=443
OBSERVATORIO_BASIC_AUTH_REALM=Observatorio CCHEN Interno

OBSERVATORIO_TLS_DIR=/srv/observatorio/tls
OBSERVATORIO_BASIC_AUTH_FILE=/srv/observatorio/nginx/.htpasswd
OBSERVATORIO_NGINX_LOG_DIR=/srv/observatorio/logs/nginx
OBSERVATORIO_BACKUP_DIR=/srv/observatorio/backups
OBSERVATORIO_ENV_FILE=.env.prod

DSPACE_FRONTEND_REST_SSL=true
DSPACE_FRONTEND_REST_PORT=443
DSPACE_FRONTEND_REST_NAMESPACE=/server
DSPACE_FRONTEND_UI_SSL=true
DSPACE_FRONTEND_UI_PORT=443
DSPACE_FRONTEND_UI_NAMESPACE=/
