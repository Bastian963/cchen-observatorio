# Dashboard/.streamlit/secrets.toml.example
# ─────────────────────────────────────────────────────────────────────────────
# Copia este archivo a .streamlit/secrets.toml y rellena con tus credenciales.
# NUNCA subas secrets.toml a Git — ya está en .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM (Groq) — requerido para el Asistente I+D ────────────────────────────
# Obtén una clave gratis en https://console.groq.com
GROQ_API_KEY = "gsk_..."

# ── Supabase — opcional; sin esto el dashboard lee solo CSVs locales ─────────
[supabase]
url          = "https://xxxx.supabase.co"
anon_key     = "eyJhbGciOiJIUzI1NiJ9..."
service_role_key = "sb_service_role_..."
data_source  = "auto"    # auto | local | supabase_public
# data_root  = ""        # Ruta absoluta a la carpeta Data/.
#                        # Dejar vacío si Data/ está al mismo nivel que Dashboard/

# ── Login interno beta — recomendado para despliegue privado ─────────────────
# Define usuarios internos sin hardcodear credenciales en el repo.
#
# [internal_auth]
# enabled = true
# beta_badge = "Beta interna"
# beta_title = "Observatorio Tecnológico CCHEN"
# beta_message = "Acceso privado para validación funcional, datos sensibles y migración progresiva del observatorio."
#
# [[internal_auth.users]]
# username = "b.ayalainostroza"
# password = "cambiar-por-una-clave-segura"
# name = "Bastián Ayala Inostroza"
# role = "admin"
# can_view_sensitive = true
#
# En vez de `password`, también puedes usar:
# password_sha256 = "<sha256-en-hex>"

# ── Autenticación Streamlit/OIDC — opcional ──────────────────────────────────
# Alternativa si luego quieres federar con Google u otro proveedor OAuth.
#
# [auth]
# providers     = ["google"]
# redirect_url  = "http://localhost:8501"
# client_id     = "xxxx.apps.googleusercontent.com"
# client_secret = "GOCSPX-..."

# ── Control de acceso a datos sensibles ──────────────────────────────────────
# Lista de emails que pueden ver capital humano y datos internos.
# Si se deja vacío, todos los usuarios autenticados tienen acceso.
#
# [observatorio]
# sensitive_access_emails = ["tu@cchen.cl", "colega@cchen.cl"]
